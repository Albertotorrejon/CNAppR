Package: CNAppR
Title: Copy Number Alterations Analysis and Integrative Exploration
Version: 1.1.0
Depends: R (>= 4.1)

Authors@R: c(
    person("Alberto", "Torrejon Aquino",
           role = c("aut", "cre"),
           email = "alberto.torrejon.aquino@gmail.com",
           comment = "Package maintainer"),
    person("Laia", "Bassaganyas", role = "aut"),
    person("Jordi", "Camps", role = "aut"),
